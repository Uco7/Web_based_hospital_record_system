<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LabTech — Patient Test Results</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Poppins:wght@600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <link rel="stylesheet" href="/css/labTech.css">
</head>
<body>

  <!-- ── Topbar ───────────────────────────────────────────── -->
  <header class="topbar">
    <button class="topbar__menu-btn" id="menuBtn" aria-label="Open navigation">
      <i class="fa-solid fa-bars"></i>
    </button>
    <a href="#" class="topbar__brand">Health<span>&nbsp;Care</span></a>
    <div class="topbar__actions">
      <div class="topbar__badge" title="Notifications">
        <i class="fa-regular fa-bell"></i>
        <span class="dot"></span>
      </div>
      <div class="topbar__avatar" title="Lab Tech">LT</div>
      <a href="/logout" class="topbar__logout">
        <i class="fa-solid fa-right-from-bracket"></i>
        <span>Log out</span>
      </a>
    </div>
  </header>

  <!-- ── Mobile off-canvas ────────────────────────────────── -->
  <div class="mobile-sidenav__overlay" id="navOverlay"></div>
  <nav class="mobile-sidenav" id="mobileNav" aria-label="Mobile navigation">
    <div class="mobile-sidenav__header">
      Health<span>&nbsp;Care</span>
      <button class="mobile-sidenav__close" id="closeNav" aria-label="Close">
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>
    <%- include('./labTech_includeFolder/sideBar') %>
  </nav>

  <div class="dashboard-shell">

    <!-- ── Desktop sidebar ──────────────────────────────────── -->
    <aside class="sidebar" aria-label="Sidebar navigation">
      <div class="sidebar__user">
        <div class="sidebar__user-avatar">LT</div>
        <div>
          <div class="sidebar__user-name">Lab Technician</div>
          <div class="sidebar__user-role">Active session</div>
        </div>
      </div>
      <%- include('./labTech_includeFolder/sideBar') %>
    </aside>

    <!-- ── Main content ─────────────────────────────────────── -->
    <main class="dashboard-content">

      <%- include('./labTech_includeFolder/appointment') %>

      <!-- Stat summary -->
      <div class="stat-grid">
        <div class="stat-card">
          <div class="stat-card__icon blue"><i class="fa-solid fa-flask"></i></div>
          <div class="stat-card__value"><%= datas ? datas.length : 0 %></div>
          <div class="stat-card__label">Total Results</div>
        </div>
        <div class="stat-card">
          <div class="stat-card__icon red"><i class="fa-solid fa-virus"></i></div>
          <div class="stat-card__value" id="hivPositive">—</div>
          <div class="stat-card__label">HIV Positive</div>
        </div>
        <div class="stat-card">
          <div class="stat-card__icon amber"><i class="fa-solid fa-droplet"></i></div>
          <div class="stat-card__value" id="malariaHigh">—</div>
          <div class="stat-card__label">High Malaria</div>
        </div>
        <div class="stat-card">
          <div class="stat-card__icon green"><i class="fa-solid fa-heart-pulse"></i></div>
          <div class="stat-card__value" id="normalBP">—</div>
          <div class="stat-card__label">Normal BP</div>
        </div>
      </div>

      <!-- Page header with toggle button -->
      <div class="page-header">
        <div>
          <div class="page-header__title">Patient Test Results</div>
          <div class="page-header__subtitle">Click "Show Results" to expand the full table</div>
        </div>
        <button class="btn-toggle-results" id="toggleResultsBtn"
                onclick="toggleResultsPanel()"
                aria-expanded="false"
                aria-controls="resultsPanel">
          <i class="fa-solid fa-table-list"></i>
          <span id="toggleBtnLabel">Show Results</span>
          <i class="fa-solid fa-chevron-down" id="toggleChevron" style="font-size:0.75rem; transition: transform 0.25s;"></i>
        </button>
      </div>

      <!-- Collapsible results panel — hidden by default -->
      <section class="results-panel" id="resultsPanel" aria-hidden="true">
        <div class="table-card">
          <div class="table-card__header">
            <div class="table-card__title">
              <i class="fa-solid fa-microscope" style="color: var(--color-accent); margin-right: 0.5rem;"></i>
              Patient Test Results
            </div>
            <div style="display:flex; align-items:center; gap:0.75rem;">
              <div class="search-wrap">
                <i class="fa-solid fa-magnifying-glass"></i>
                <input type="text" id="customSearchBox" class="search-input" placeholder="Search results…" aria-label="Search test results">
              </div>
              <button class="appointments-panel__close"
                      onclick="toggleResultsPanel()"
                      title="Hide results"
                      aria-label="Close results panel">
                <i class="fa-solid fa-xmark"></i>
              </button>
            </div>
          </div>

          <div class="table-scroll">
            <table class="data-table" id="resultsTable">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Phone</th>
                  <th>Genotype</th>
                  <th>Blood Group</th>
                  <th>Remark</th>
                  <th>Illness</th>
                  <th>Pulse</th>
                  <th>BP</th>
                  <th>HIV</th>
                  <th>AIDS</th>
                  <th>Sugar</th>
                  <th>Fever</th>
                  <th>Pregnancy</th>
                  <th>Malaria</th>
                  <th>Date</th>
                  <th>Doctor</th>
                  <th>Doc Email</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <% if (datas && datas.length > 0) { %>
                  <% datas.forEach((result, index) => { %>
                    <tr>
                      <td><%= index + 1 %></td>
                      <td><strong><%= result.fName %></strong></td>
                      <td><%= result.patient_email %></td>
                      <td><%= result.phone_no %></td>
                      <td><span class="badge badge--neutral"><%= result.genotype %></span></td>
                      <td><span class="badge badge--neutral"><%= result.blood_group %></span></td>
                      <td><%= result.docRemark %></td>
                      <td><%= result.illness %></td>
                      <td><%= result.pulseRate %></td>
                      <td>
                        <span class="badge <%= result.bloodPressure === 'Normal' ? 'badge--positive' : result.bloodPressure === 'Very High' ? 'badge--negative' : 'badge--high' %>">
                          <%= result.bloodPressure %>
                        </span>
                      </td>
                      <td>
                        <span class="badge <%= result.hivStatus === 'Positive' ? 'badge--negative' : 'badge--positive' %>">
                          <%= result.hivStatus %>
                        </span>
                      </td>
                      <td>
                        <span class="badge <%= result.aidsStatus === 'Positive' ? 'badge--negative' : 'badge--positive' %>">
                          <%= result.aidsStatus %>
                        </span>
                      </td>
                      <td><%= result.sugarLevel %></td>
                      <td><%= result.feverStatus %></td>
                      <td>
                        <% if (result.pregnancyStatus) { %>
                          <span class="badge <%= result.pregnancyStatus === 'Positive' ? 'badge--high' : 'badge--neutral' %>">
                            <%= result.pregnancyStatus %>
                          </span>
                        <% } else { %>—<% } %>
                      </td>
                      <td>
                        <span class="badge <%= result.malariaStatus === 'High' ? 'badge--negative' : result.malariaStatus === 'Negative' ? 'badge--positive' : 'badge--high' %>">
                          <%= result.malariaStatus %>
                        </span>
                      </td>
                      <td><%= new Date(result.currentDate).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' }) %></td>
                      <td><%= result.doc_name %></td>
                      <td><%= result.doc_email %></td>
                      <td>
                        <a href="/labtech/fillCard/<%= result._id %>" class="btn-icon fill">
                          <i class="fa-solid fa-file-pen"></i>&nbsp;Fill Card
                        </a>
                      </td>
                    </tr>
                  <% }); %>
                <% } else { %>
                  <tr>
                    <td colspan="20">
                      <div class="table-empty">
                        <i class="fa-solid fa-flask"></i>
                        <p>No test results available yet.</p>
                      </div>
                    </td>
                  </tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div><!-- /table-card -->
      </section><!-- /results-panel -->

    </main>
  </div><!-- /dashboard-shell -->

  <style>
    .btn-toggle-results {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      height: 2.4rem;
      padding: 0 1.1rem;
      background: var(--color-accent);
      color: #fff;
      font-weight: 600;
      font-size: 0.875rem;
      font-family: var(--font-body);
      border: none;
      border-radius: var(--radius-sm);
      cursor: pointer;
      transition: background 0.15s;
    }
    .btn-toggle-results:hover { background: var(--color-accent-dark); }

    .results-panel {
      display: none;
    }
    .results-panel.is-open {
      display: block;
      animation: slideDown 0.22s ease;
    }
    @keyframes slideDown {
      from { opacity: 0; transform: translateY(-6px); }
      to   { opacity: 1; transform: translateY(0); }
    }
  </style>

  <script src="/js/labTech.js"></script>
  <script>
    // ── Toggle results panel ────────────────────────────────
    function toggleResultsPanel() {
      const panel   = document.getElementById('resultsPanel');
      const btn     = document.getElementById('toggleResultsBtn');
      const label   = document.getElementById('toggleBtnLabel');
      const chevron = document.getElementById('toggleChevron');
      const isOpen  = panel.classList.toggle('is-open');

      btn.setAttribute('aria-expanded', isOpen);
      panel.setAttribute('aria-hidden', !isOpen);
      label.textContent = isOpen ? 'Hide Results' : 'Show Results';
      chevron.style.transform = isOpen ? 'rotate(180deg)' : 'rotate(0deg)';
    }

    // ── Mobile nav ──────────────────────────────────────────
    const menuBtn     = document.getElementById('menuBtn');
    const closeNavBtn = document.getElementById('closeNav');
    const mobileNav   = document.getElementById('mobileNav');
    const overlay     = document.getElementById('navOverlay');

    menuBtn.addEventListener('click', () => {
      mobileNav.classList.add('is-open');
      overlay.classList.add('is-visible');
      document.body.classList.add('nav-open');
    });
    [closeNavBtn, overlay].forEach(el => el.addEventListener('click', () => {
      mobileNav.classList.remove('is-open');
      overlay.classList.remove('is-visible');
      document.body.classList.remove('nav-open');
    }));

    // ── Live search ─────────────────────────────────────────
    document.getElementById('customSearchBox').addEventListener('input', function() {
      const q = this.value.toLowerCase();
      document.querySelectorAll('#resultsTable tbody tr').forEach(row => {
        row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
      });
    });

    // ── Quick stats from rendered rows ───────────────────────
    let hivPos = 0, malariaHigh = 0, normalBP = 0;
    document.querySelectorAll('#resultsTable tbody tr').forEach(row => {
      const cells = row.querySelectorAll('td');
      if (cells.length < 16) return;
      if (cells[10].textContent.trim() === 'Positive') hivPos++;
      if (cells[15].textContent.trim() === 'High') malariaHigh++;
      if (cells[9].textContent.trim() === 'Normal') normalBP++;
    });
    document.getElementById('hivPositive').textContent = hivPos;
    document.getElementById('malariaHigh').textContent = malariaHigh;
    document.getElementById('normalBP').textContent    = normalBP;
  </script>
</body>
</html>
