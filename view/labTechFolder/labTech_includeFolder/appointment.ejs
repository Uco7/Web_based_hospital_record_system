<!--
  Booked-appointments panel. Hidden by default; toggled open by the
  "Booked Appointment" links in sideBar.ejs (desktop) and navBar.ejs
  (mobile), both of which call toggleAppointmentsPanel() below.
-->
<section class="appointments-panel" id="appointmentsPanel">
    <div class="appointments-panel__header">
        <h2 class="appointments-panel__title">Booked Sessions</h2>
        <button type="button" class="appointments-panel__close" onclick="toggleAppointmentsPanel()" aria-label="Close booked sessions">
            <i class="fa-solid fa-xmark"></i>
        </button>
    </div>

    <div class="table-card__scroll">
        <table class="data-table">
            <thead>
                <tr>
                    <th>S/N</th>
                    <th>Candidate Name</th>
                    <th>Email</th>
                    <th>Phone Number</th>
                    <th>Address</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                <% if (appointment && appointment.length > 0) { %>
                    <% appointment.forEach((data, index) => { %>
                        <tr>
                            <td><%= index + 1 %></td>
                            <td><%= data.name %></td>
                            <td><%= data.email %></td>
                            <td><%= data.phone_no %></td>
                            <td><%= data.address %></td>
                            <td>
                                <a class="btn-view" href="#">
                                    <i class="fa-solid fa-eye"></i>
                                    <span>View</span>
                                </a>
                            </td>
                        </tr>
                    <% }); %>
                <% } else { %>
                    <tr>
                        <td colspan="6">
                            <div class="table-empty">
                                <i class="fa-regular fa-calendar"></i>
                                <p>No booked sessions yet.</p>
                            </div>
                        </td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
</section>

<script>
    function toggleAppointmentsPanel() {
        document.getElementById('appointmentsPanel').classList.toggle('is-open');
    }
</script>
