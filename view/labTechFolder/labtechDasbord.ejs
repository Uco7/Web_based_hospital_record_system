<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LabTech Dashboard — Patient Cards</title>
    <link href="/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/labTech.css">
    <script src="https://kit.fontawesome.com/56adb67a5b.js" crossorigin="anonymous"></script>
</head>
<body>

    <%- include('./labTech_includeFolder/navBar') %>
    <%- include('./labTech_includeFolder/sideBar') %>
    <%- include('./labTech_includeFolder/appointment') %>

        <div class="page-header">
            <h1 class="h4">Patient Card Records</h1>
            <input type="text" id="customSearchBox" class="form-control search-input" placeholder="Search records...">
        </div>

        <div class="table-card">
            <div class="table-card__scroll">
                <table class="data-table" id="cardRecordsTable">
                    <thead>
                        <tr>
                            <th>S/N</th>
                            <th>Candidate Name</th>
                            <th>Phone Number</th>
                            <th>Card Number</th>
                            <th>Amount</th>
                            <th>Expiration Date</th>
                            <th>Purchased Date</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (datas && datas.length > 0) { %>
                            <% datas.forEach((item, index) => { %>
                                <tr>
                                    <td><%= (currentPage - 1) * limit + index + 1 %></td>
                                    <td><%= item.fName ? item.fName : 'No data' %></td>
                                    <td><%= item.patient && item.patient.phone_no ? item.patient.phone_no : 'No data' %></td>
                                    <td><%= item.paymentReference ? item.paymentReference : 'No data' %></td>
                                    <td>NGN <%= item.amount ? item.amount : 'No data' %></td>
                                    <td><%= item.expiration_date ? new Date(item.expiration_date).toLocaleDateString('en-US') : 'Pending' %></td>
                                    <td><%= item.purchase_date ? new Date(item.purchase_date).toLocaleDateString('en-US') : 'Pending' %></td>
                                    <td>
                                        <a class="btn-view" href="/labTechs/fill/card?id=<%= item._id %>">
                                            <i class="fa-solid fa-pen-to-square"></i>
                                            <span>Fill card</span>
                                        </a>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } else { %>
                            <tr>
                                <td colspan="8">
                                    <div class="table-empty">
                                        <i class="fa-regular fa-folder-open"></i>
                                        <p>No card records yet.</p>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>

    </main>
    </div>

    <script src="/jquery/jquery.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/5.1.0/js/bootstrap.bundle.min.js"></script>
    <script src="/js/userDashBord.js"></script>
    <script src="/js/labTech.js"></script>
    <script>
        // Simple client-side filter across the visible row text.
        document.getElementById('customSearchBox').addEventListener('input', function (e) {
            const query = e.target.value.toLowerCase();
            document.querySelectorAll('#cardRecordsTable tbody tr').forEach((row) => {
                row.style.display = row.textContent.toLowerCase().includes(query) ? '' : 'none';
            });
        });
    </script>
</body>
</html>
