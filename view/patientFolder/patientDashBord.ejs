<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Patient Dashboard — HealthCare</title>
    <link href="/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <script src="https://kit.fontawesome.com/56adb67a5b.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" type="text/css" href="https://cdn.datatables.net/1.11.5/css/jquery.dataTables.css">
    <link rel="stylesheet" href="/css/staff.css">
</head>
<body>

    <!-- ===================== MOBILE SIDENAV ===================== -->
    <div class="nav-sm admin-navSm">
        <span class="menu-icon" onclick="openNav()" role="button" aria-label="Open menu">
            <i class="fa-solid fa-bars"></i>
        </span>
        <div id="mySidenav" class="sidenav sm-sidde">
            <a href="javascript:void(0)" class="closebtn" onclick="closeNav()">&times;</a>
            <h1>Dashboard</h1>

            <ul class="nav flex-column cont">
                <li class="active" id="home">
                    <a href="/patients/dashbord" aria-current="page">Home</a>
                </li>
                <li>
                    <i class="fa-solid fa-user"></i>
                    <a href="/patients/profile/page">My Profile</a>
                </li>
                <li id="purchase_card">
                    <i class="fa-regular fa-id-card"></i>
                    <a href="#">Purchase Card</a>
                </li>
                <li id="patient-cards">
                    <i class="fa-regular fa-id-card"></i>
                    <a href="#">Purchased Cards</a>
                </li>
                <li id="test-result">
                    <i class="fa-solid fa-vials"></i>
                    <a href="#">Treatment Schedule</a>
                </li>
            </ul>
        </div>
    </div>

    <!-- ===================== TOP NAV ===================== -->
    <nav class="navbar navbar-expand-lg nav-big" id="navBig">
        <div class="container-fluid">
            <img src="/image/ucogo.png" alt="logo" width="50" height="50">

            <div class="notification">
                <a class="nav-link" href="#">
                    <i class="fa-regular fa-bell"></i>
                    <span id="red">1</span>
                </a>
            </div>

            <ul class="nav justify-content-end align-items-center">
                <li class="nav-item userimg">
                    <img src="<%= patientData.profileImage ? 'data:image/jpeg;base64,' + patientData.profileImage : '/image/avatar-placeholder.png' %>"
                        alt="Profile photo">
                </li>
                <li class="nav-item">
                    <a class="nav-link log-out" href="/logout">Log out</a>
                </li>
            </ul>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">

            <!-- ===================== DESKTOP SIDEBAR ===================== -->
            <div class="col-12 col-md-3 col-lg-2 sidebar">
                <ul class="nav flex-column cont">
                    <li class="active" id="home">
                        <a href="/patients/dashbord" aria-current="page">Home</a>
                    </li>
                    <li>
                        <i class="fa-solid fa-user"></i>
                        <a href="/patients/profile/page">My Profile</a>
                    </li>
                    <li id="purchase_card">
                        <i class="fa-regular fa-id-card"></i>
                        <a href="#">Purchase Card</a>
                    </li>
                    <li id="patient-cards">
                        <i class="fa-regular fa-id-card"></i>
                        <a href="#">Purchased Cards</a>
                    </li>
                    <li id="test-result">
                        <i class="fa-solid fa-vials"></i>
                        <a href="#">Test Results</a>
                    </li>
                </ul>
            </div>

            <!-- ===================== MAIN CONTENT ===================== -->
            <div class="col-12 col-md-9 col-lg-10 main-content">

                <!-- Home / stats -->
                <div class="box-cont" id="homeStats">
                    <h2 class="welcome-heading">Welcome back, <%= patientData.fName %></h2>

                    <div class="boxes">
                        <div class="box box1">
                            <span class="num" id="num1">
                                <%= patientTestResult ? 1 : 0 %>
                            </span>
                            <span class="box-txt" id="box-txt1">Test Results</span>
                        </div>

                        <div class="box box2">
                            <span class="num" id="num2">
                                <%= patientCard ? 1 : 0 %>
                            </span>
                            <span class="box-txt" id="box-txt2">Cards Purchased</span>
                        </div>

                        <div class="box box3">
                            <span class="num" id="num3">0</span>
                            <span class="box-txt" id="box-txt3">Upcoming Appointments</span>
                        </div>
                    </div>
                </div>

                <!-- Test results table -->
                <div class="container wrap-table testTb" id="testTb" style="display: none;">
                    <div class="resolve-complaint">
                        <span class="h4">Medical Test Results</span>
                        <input type="text" id="customSearchBox" class="form-control custom-search-input"
                            placeholder="Search...">
                    </div>

                    <table>
                        <thead>
                            <tr>
                                <th>S/N</th>
                                <th>Pulse Rate</th>
                                <th>BP Rate</th>
                                <th>HIV Test</th>
                                <th>AIDS Test</th>
                                <th>Sugar Level</th>
                                <th>Fever</th>
                                <th>Malaria</th>
                                <th>Pregnancy Test</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (patientTestResult) { %>
                            <tr>
                                <td>1</td>
                                <td><%= patientTestResult.pulseRate %></td>
                                <td><%= patientTestResult.bloodPressure %></td>
                                <td><%= patientTestResult.hivStatus %></td>
                                <td><%= patientTestResult.aidsStatus %></td>
                                <td><%= patientTestResult.sugarLevel %></td>
                                <td><%= patientTestResult.feverStatus %></td>
                                <td><%= patientTestResult.malariaStatus %></td>
                                <td><%= patientTestResult ? patientTestResult.pregnancyStatus : "NAN" %></td>
                                <td><%= new Date(patientTestResult.currentDate).toLocaleDateString() %></td>
                            </tr>
                            <% } else { %>
                            <tr>
                                <td colspan="10">No data</td>
                            </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>

                <!-- Purchased cards table -->
                <div class="container wrap-table cardTb normal-tb" id="cardTb" style="display: none;">
                    <div class="resolve-complaint">
                        <span class="h4">Purchased Cards Records</span>
                        <input type="text" id="customSearchBox" class="form-control custom-search-input"
                            placeholder="Search...">
                    </div>

                    <table>
                        <thead>
                            <tr>
                                <th>S/N</th>
                                <th>Candidate Name</th>
                                <th>Candidate Email</th>
                                <th>Card Number</th>
                                <th>Expiration Date</th>
                                <th>Purchased Date</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <% if (patientCard) { %>
                                <td>1</td>
                                <td><%= patientCard.fName %></td>
                                <td><%= patientCard.email || 'N/A' %></td>
                                <td><%= patientCard.card_number %></td>
                                <td><%= new Date(patientCard.expiration_date).toLocaleDateString() %></td>
                                <td><%= new Date(patientCard.purchase_date).toLocaleDateString() %></td>
                                <td><a href="/patients/purchased/card/page?id=<%= patientCard._id %>">View</a></td>
                                <% } else { %>
                                <td colspan="7">No data</td>
                                <% } %>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Buy card form -->
                <div class="form wrap-form buycard" id="buycard" style="display: none;">
                    <div class="card">
                        <div class="card-header text-center">
                            <h3>Patient Purchased Card</h3>
                        </div>
                        <div class="card-body">
                            <form id="paymentForm" action="/initialize-payment" method="POST">

                                <input type="hidden" name="patientId" id="patientId" value="<%= patientData._id %>">

                                <div class="form-group">
                                    <label for="fName">Full Name</label>
                                    <input type="text" name="fName" id="fName" class="form-control"
                                        placeholder="Full Name" required>
                                </div>
                                <div class="form-group">
                                    <label for="email">Email</label>
                                    <input type="email" name="email" id="email" class="form-control"
                                        placeholder="Email" required>
                                </div>
                                <div class="form-group">
                                    <label for="amount">Amount</label>
                                    <input type="number" name="amount" id="amount" class="form-control" value="500"
                                        required>
                                </div>

                                <div class="btn-cont text-center">
                                    <button type="submit" class="btn-print">Purchase Card</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script src="/jquery/jquery.min.js"></script>
    <script src="https://js.paystack.co/v1/inline.js"></script>
    <script src="/bootstrap/dist/js/bootstrap.bundle.js"></script>
    <script src="/js/patientDashBord.js"></script>
    <script src="/js/userDashBord.js"></script>
    <script src="/js/labTech.js"></script>

    <script>
        function openNav() {
            document.getElementById('mySidenav').style.width = '100%';
            document.getElementById('mySidenav').style.height = '40%';
        }

        function closeNav() {
            document.getElementById('mySidenav').style.width = '0';
        }
    </script>
</body>
</html>