<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Patient Dashboard — HealthCare</title>
    <link href="/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    <script src="https://kit.fontawesome.com/56adb67a5b.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="/css/staff.css">
</head>
<body>

    <nav class="navbar navbar-expand-lg">
        <div class="container">
            <h1>Health<span id="care">Care</span></h1>

            <ul class="li-center">
                <!-- <li class="nav-item"><a href="#">Services</a></li>
                <li class="nav-item"><a href="#">About Us</a></li> -->
            </ul>

            <ul class="nav justify-content-end">
                <li class="nav-item" id="log-out">
                    <a href="/logout">Log Out</a>
                </li>
            </ul>
        </div>
    </nav>

    <div class="container-fluid">
        <div class="row">

            <!-- ===================== SIDEBAR ===================== -->
            <div class="col-12 col-md-3 col-lg-2 sidebar">
                <ul>
                    <li class="active">
                        <a href="#" aria-current="page">Home</a>
                    </li>
                    <li>
                        <i class="fa-solid fa-user"></i>
                        <a href="#">My Profile</a>
                    </li>
                    <li>
                        <i class="fa-regular fa-id-card"></i>
                        <a href="#">Purchase Card</a>
                    </li>
                    <li>
                        <i class="fa-regular fa-id-card"></i>
                        <a href="#">Purchased Cards</a>
                    </li>
                    <li>
                        <i class="fa-solid fa-vials"></i>
                        <a href="#">Test Results</a>
                    </li>
                </ul>
            </div>

            <!-- ===================== MAIN CONTENT ===================== -->
            <div class="col-12 col-md-9 col-lg-10 main-content">

                <!-- purchase card form -->
                <div class="wrap-form">
                    <div class="card">
                        <div class="card-header text-center">
                            <h3>Patient Purchased Card</h3>
                        </div>
                        <div class="card-body">
                            <form action="/login" method="post">

                                <div class="form-group">
                                    <input type="text" name="fName" id="fName" class="form-control"
                                        placeholder="First Name" required>
                                </div>
                                <div class="form-group">
                                    <input type="text" name="phone_no" id="phone_no" class="form-control"
                                        placeholder="Phone Number" required>
                                </div>
                                <div class="form-group">
                                    <input type="text" name="address" id="address" class="form-control"
                                        placeholder="Address" required>
                                </div>
                                <div class="form-group">
                                    <input type="text" name="doc-remark" id="doc-remark" class="form-control"
                                        placeholder="Doctor Previous Remark" required>
                                </div>
                                <div class="form-group">
                                    <input type="text" name="genotype" id="genotype" class="form-control"
                                        placeholder="Genotype" required>
                                </div>
                                <div class="form-group">
                                    <input type="text" name="blood_group" id="blood_group" class="form-control"
                                        placeholder="Blood Group" required>
                                </div>
                                <div class="form-group">
                                    <input type="text" name="illness" id="illness" class="form-control"
                                        placeholder="Diagnosed Illness" required>
                                </div>
                                <div class="form-group">
                                    <label for="purchase_date">Date of Purchase</label>
                                    <input type="date" name="purchase_date" id="purchase_date" class="form-control"
                                        required>
                                </div>
                                <div class="form-group">
                                    <label for="Expiration_date">Expiration Date</label>
                                    <input type="date" name="expiration_date" id="Expiration_date"
                                        class="form-control" required>
                                </div>

                                <div class="btn-cont text-center">
                                    <input type="checkbox" name="status" id="status">
                                    <span>Purchased</span>
                                    <button type="submit" class="btn-print">Print</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script src="/bootstrap/dist/js/bootstrap.bundle.js"></script>
    <script src="/js/labTech.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const navItems = document.querySelectorAll('.sidebar ul li');
            let active = document.querySelector('.sidebar ul li.active');

            navItems.forEach((item) => {
                item.addEventListener('mouseenter', () => {
                    if (active) active.classList.remove('active');
                    item.classList.add('active');
                    active = item;
                });
            });
        });
    </script>
</body>
</html>