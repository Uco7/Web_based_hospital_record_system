<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Patient Cards Records</title>
    <script src="https://kit.fontawesome.com/56adb67a5b.js" crossorigin="anonymous"></script>
    <link rel="stylesheet" href="/css/admindashbord.css">
</head>
<body>

    <%- include('./adminInclude_folder/navBar') %>

    <div class="dashboard-shell">

        <%- include('./adminInclude_folder/sideBar') %>

        <main class="dashboard-content" id="main">

            <div class="page-header">
                <div>
                    <h1 class="page-header__title">Patient Cards Records</h1>
                    <div class="page-header__subtitle">Full medical test results and clinical data for all patients</div>
                </div>
                <div class="search-wrap">
                    <i class="fa-solid fa-magnifying-glass"></i>
                    <input type="text" id="customSearchBox" class="search-input" placeholder="Search records...">
                </div>
            </div>

            <!-- Appointments Panel -->
            <div class="appointments-panel" id="appointmentsPanel">
                <%- include('./adminInclude_folder/appointent') %>
            </div>

            <div class="table-card prec-tb">
                <div class="table-card__header">
                    <div class="table-card__title">
                        <i class="fa-solid fa-file-medical" style="color: var(--color-accent);"></i>
                        Patient Medical Records
                    </div>
                </div>
                <div class="table-scroll">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>S/N</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Address</th>
                                <th>Illness</th>
                                <th>Genotype</th>
                                <th>Blood Group</th>
                                <th>HIV</th>
                                <th>AIDS</th>
                                <th>Sugar</th>
                                <th>Fever</th>
                                <th>Pregnancy</th>
                                <th>Malaria</th>
                                <th>Remark</th>
                                <th>Update</th>
                                <th>Delete</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (patientRecords && patientRecords.length > 0) { %>
                                <% patientRecords.forEach((record, index) => { %>
                                    <tr>
                                        <td><%= index + 1 %></td>
                                        <td><strong><%= record.fName %></strong></td>
                                        <td><%= record.patient_email %></td>
                                        <td><%= record.phone_no %></td>
                                        <td><%= record.address %></td>
                                        <td><%= record.illness %></td>
                                        <td><span class="badge badge--neutral"><%= record.genotype %></span></td>
                                        <td><span class="badge badge--gold"><%= record.blood_group %></span></td>
                                        <td><span class="badge <%= record.hivStatus === 'Positive' ? 'badge--negative' : 'badge--positive' %>"><%= record.hivStatus %></span></td>
                                        <td><span class="badge <%= record.aidsStatus === 'Positive' ? 'badge--negative' : 'badge--positive' %>"><%= record.aidsStatus %></span></td>
                                        <td><%= record.sugarLevel %></td>
                                        <td><%= record.feverStatus %></td>
                                        <td><%= record.pregnancyStatus %></td>
                                        <td><%= record.malariaStatus %></td>
                                        <td><%= record.docRemark || '—' %></td>
                                        <td>
                                            <a href="/admin/test/result/page?id=<%= record._id %>" class="btn-action btn-action--edit">
                                                <i class="fa-solid fa-pen"></i> Edit
                                            </a>
                                        </td>
                                        <td>
                                            <a href="#" class="btn-action btn-action--delete deleteTestBtn" data-id="<%= record._id %>">
                                                <i class="fa-solid fa-trash"></i> Del
                                            </a>
                                        </td>
                                    </tr>
                                <% }) %>
                            <% } else { %>
                                <tr>
                                    <td colspan="17">
                                        <div class="table-empty">
                                            <i class="fa-solid fa-file-medical"></i>
                                            <p>No patient records found.</p>
                                        </div>
                                    </td>
                                </tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

        </main>
    </div>

    <script src="/jquery/jquery.min.js"></script>
    <script src="/js/admin.js"></script>
    <script src="/js/deleteRecord.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
